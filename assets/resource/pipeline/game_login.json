                    "王城公布栏",
                    "活动公告",
                    "最新公告"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    360,
                    1155
                ]
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "max_hit": 3
    },
    "GameCloseSignIn": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    720,
