{
    "GameLoginStart": {
        "action": {
            "type": "StopApp",
            "param": {
                "package": "com.pinkcore.tkfm"
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "next": [
            "GameLoginLaunch"
        ]
    },
    "GameLoginLaunch": {
        "action": {
            "type": "StartApp",
            "param": {
                "package": "com.pinkcore.tkfm"
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "timeout": 180000,
        "next": [
            "[JumpBack]CommonWaitLoading",
            "[JumpBack]GameCloseAnnouncement",
            "[JumpBack]GameCloseEventSignIn",
            "GameTapTitleScreen"
        ]
    },
    "GameTapTitleScreen": {
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__GameTitleTapToStartOcr",
                    "__GameTitleVersionOcr"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    360,
                    1135
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "next": [
            "[JumpBack]CommonWaitLoading",
            "[JumpBack]GameCloseEventSignIn",
            "[JumpBack]GameTapTitleScreen",
            "GameAwaitGiftAfterTitle"
        ],
        "max_hit": 10
    },
    "GameAwaitGiftAfterTitle": {
        "timeout": 120000,
        "next": [
            "[JumpBack]CommonWaitLoading",
            "[JumpBack]GameCloseAnnouncement",
            "[JumpBack]GameCloseEventSignIn",
            "[JumpBack]GameCloseSignIn",
            "GameCloseGift",
            "GameMainReady"
        ]
    },
    "GameCloseEventSignIn": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "GameEventSignInName",
                    "__GameEventSignInRewardMarker"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    624,
                    664
                ]
            }
        },
        "post_wait_freezes": {
            "time": 800,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "max_hit": 2
    },
    "GameEventSignInName": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    80,
                    500,
                    560,
                    260
                ],
                "threshold": 0.25,
                "expected": [
                    "耐久直播",
                    "耐久世播"
                ]
            }
        }
    },
    "__GameEventSignInRewardMarker": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    80,
                    500,
                    560,
                    500
                ],
                "threshold": 0.25,
                "expected": [
                    "挑战奖励",
                    "LOGIN REWARDS",
                    "UTC+8"
                ]
            }
        }
    },
    "GameCloseAnnouncement": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    100,
                    150,
                    520,
                    120
                ],
                "threshold": 0.3,
                "expected": [
                    "王城公布栏",
                    "活动公告",
                    "最新公告"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    360,
                    1205
                ]
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "max_hit": 3
    },
    "__GameTitleTapToStartOcr": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "TAPTO START",
                    "TAP TO START",
                    "TAPTOSTART",
                    "TAPTOSTAR",
                    "TOUCH SCREEN"
                ],
                "threshold": 0.3,
                "roi": [
                    180,
                    1060,
                    360,
                    170
                ]
            }
        }
    },
    "__GameTitleVersionOcr": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "Ver",
                    "Ver.",
                    "Ver.2.2.1"
                ],
                "threshold": 0.3,
                "roi": [
                    500,
                    1200,
                    220,
                    80
                ]
            }
        }
    },
    "GameCloseSignIn": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    720,
                    1280
                ],
                "threshold": 0.3,
                "expected": [
                    "6月",
                    "奖励已送至仓库",
                    "每日获得(连续30天)",
                    "每日获得(连续30 天)",
                    "签到"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    40,
                    60
                ]
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "next": [
            "[JumpBack]CommonWaitLoading",
            "GameAwaitGiftAfterTitle"
        ],
        "max_hit": 2
    },
    "GameCloseGift": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    720,
                    1280
                ],
                "threshold": 0.3,
                "expected": [
                    "STEP",
                    "限时",
                    "精选",
                    "月卡"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    40,
                    60
                ]
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "next": [
            "[JumpBack]CommonWaitLoading",
            "[JumpBack]GameCloseGift",
            "GameMainReady"
        ],
        "max_hit": 2
    },
    "__GameGiftBackButton": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "GameLogin/BackButton.png",
                "roi": [
                    0,
                    30,
                    150,
                    90
                ],
                "threshold": 0.75
            }
        }
    },
    "__GameGiftTopTabsOcr": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    90,
                    80,
                    550,
                    100
                ],
                "expected": [
                    "STEP",
                    "限时",
                    "精选",
                    "月卡"
                ]
            }
        }
    },
    "GameMainReady": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "__GameMainExpeditionButton",
                    "__GameMainTrainingButton"
                ]
            }
        },
        "action": {
            "type": "StopTask"
        }
    },
    "__GameMainExpeditionButton": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    450,
                    820,
                    230,
                    160
                ],
                "expected": [
                    "出征"
                ]
            }
        }
    },
    "__GameMainTrainingButton": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    570,
                    1000,
                    120,
                    110
                ],
                "expected": [
                    "调教"
                ]
            }
        }
    }
}
