{
    "GameLoginStart": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "StopApp",
            "param": {
                "package": "com.pinkcore.tkfm"
            }
        },
        "next": [
            "GameLoginLaunch"
        ]
    },
    "GameLoginLaunch": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "StartApp",
            "param": {
                "package": "com.pinkcore.tkfm"
            }
        },
        "next": [
            "GameLoginDispatch"
        ]
    },
    "GameLoginDispatch": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "DoNothing"
        },
        "timeout": 360000,
        "next": [
            "[JumpBack]CommonWaitLoading",
            "[JumpBack]GameWaitResourceCheck",
            "[JumpBack]GameCloseAnnouncement",
            "[JumpBack]GameCloseEventSignIn",
            "[JumpBack]GameCloseSignIn",
            "[JumpBack]GameCloseGift",
            "[JumpBack]GameTapTitleScreen",
            "GameMainReady"
        ]
    },
    "GameTapTitleScreen": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "TAPTO START",
                    "TAP TO START",
                    "TAPTOSTART",
                    "TAPTOSTAR",
                    "Ver",
                    "Ver.",
                    "Ver.2.2.1"
                ],
                "threshold": 0.3,
                "roi": [
                    180,
                    1060,
                    540,
                    220
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    360,
                    1135
                ]
            }
        },
        "rate_limit": 2000,
        "max_hit": 5
    },
    "GameWaitResourceCheck": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "资源检查中",
                    "档案读取中"
                ],
                "roi": [
                    180,
                    1120,
                    360,
                    130
                ]
            }
        }
    },
    "GameCloseEventSignIn": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    80,
                    500,
                    560,
                    500
                ],
                "threshold": 0.25,
                "expected": [
                    "挑战奖励",
                    "LOGIN REWARDS",
                    "UTC+8"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    360,
                    1135
                ]
            }
        },
        "post_wait_freezes": {
            "time": 800,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "max_hit": 2
    },
    "GameCloseAnnouncement": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    100,
                    150,
                    520,
                    120
                ],
