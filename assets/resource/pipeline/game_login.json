    "GameCloseGift": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    90,
                    80,
                    550,
                    100
                ],
                "expected": [
                    "STEP",
                    "限时",
                    "精选",
                    "月卡"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    40,
                    75
                ]
            }
