                0,
                0
            ]
        },
        "max_hit": 3
    },
    "GameMainReady": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "CommonMainReady"
                ]
            }
        },
        "action": {
            "type": "StopTask"
        }
    }
}
